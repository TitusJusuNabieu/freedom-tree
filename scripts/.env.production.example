# ── apps/web/.env.production.local ───────────────────────────────────────────
# Copy this file to apps/web/.env.production.local on the server and fill in
# the real values. This file must NEVER be committed to git.
#
#   cp scripts/.env.production.example apps/web/.env.production.local
#   nano apps/web/.env.production.local

# PostgreSQL connection string for the production database
# Example: postgresql://freedomtree:strongpassword@localhost:5432/freedomtree_prod
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/freedomtree_prod"

# HS256 secret for signing JWT access tokens (mobile API)
# Generate with:  openssl rand -base64 32
JWT_ACCESS_SECRET="REPLACE_WITH_RANDOM_SECRET"

# NextAuth session secret (dashboard login)
# Generate with:  openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_ANOTHER_RANDOM_SECRET"

# The public URL where the web app is accessible
# This must match exactly what users type in their browser
# Pattern: http://YOUR_DIGITALOCEAN_IP:8080
NEXTAUTH_URL="http://YOUR_SERVER_IP:8080"
